PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
LAST_FM_API_KEY=<lastfm-api-key>
FANART_TV_API_KEY=<fanart-tv-api-key>
THEAUDIODB_API_KEY=123
# Shared secret between the SvelteKit /api/digests/generate endpoint and the
# scripts/run-weekly-digests.mjs scheduler. Generate with `openssl rand -hex 32`.
DIGEST_SCHEDULER_SECRET=<random-hex>
# Optional override for the scheduler's target host. Defaults to http://127.0.0.1:3200.
# ALBUMZ_BASE_URL=http://127.0.0.1:3200
