[Unit]
Description=Albumz weekly digest generator (one-shot, invoked by .timer)
# Generation needs the SvelteKit server up to handle the POSTs.
After=albumz.service ollama.service
Requires=albumz.service

[Service]
Type=oneshot
User=zedzee
Group=zedzee
WorkingDirectory=/home/zedzee/mine/apps/albumz
EnvironmentFile=/home/zedzee/mine/apps/albumz/.env
# nvm-managed node — update this path when the node version changes
ExecStart=/home/zedzee/.nvm/versions/node/v24.14.1/bin/node scripts/run-weekly-digests.mjs
StandardOutput=journal
StandardError=journal
SyslogIdentifier=albumz-digest
